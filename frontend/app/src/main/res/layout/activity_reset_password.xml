<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="48dp">

            <!-- Back Button -->
            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="?attr/colorOnBackground"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginStart="-12dp"
                android:layout_marginTop="8dp" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reset Password"
                android:textColor="?attr/colorOnBackground"
                android:textSize="32sp"
                android:fontFamily="sans-serif-black"
                android:layout_marginTop="40dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create a strong password to secure your MotoVista account."
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="4dp" />

            <!-- New Password Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New Password"
                android:textColor="?attr/colorOnBackground"
                android:textSize="14sp"
                android:fontFamily="sans-serif-bold"
                android:layout_marginTop="48dp"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_premium_input_container"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_lock"
                    app:tint="?attr/colorOnSurfaceVariant"
                    android:layout_marginEnd="12dp" />

                <EditText
                    android:id="@+id/et_new_password"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Create new password"
                    android:textColor="?attr/colorOnSurface"
                    android:textColorHint="?attr/colorOutline"
                    android:textSize="16sp"
                    android:background="@null"
                    android:inputType="textPassword" />
            </LinearLayout>

            <!-- Confirm Password Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confirm New Password"
                android:textColor="?attr/colorOnBackground"
                android:textSize="14sp"
                android:fontFamily="sans-serif-bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_premium_input_container"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_lock"
                    app:tint="?attr/colorOnSurfaceVariant"
                    android:layout_marginEnd="12dp" />

                <EditText
                    android:id="@+id/et_confirm_password"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Confirm new password"
                    android:textColor="?attr/colorOnSurface"
                    android:textColorHint="?attr/colorOutline"
                    android:textSize="16sp"
                    android:background="@null"
                    android:inputType="textPassword" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Submit Button -->
            <Button
                android:id="@+id/btn_reset_password"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Update Password"
                android:textColor="?attr/colorOnPrimary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-bold"
                android:background="@drawable/bg_premium_primary_btn"
                android:elevation="6dp"
                android:layout_marginTop="56dp" />

        </LinearLayout>

    </ScrollView>

    <ProgressBar
        android:id="@+id/loading_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="?attr/colorPrimary"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
