<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="16dp"
    app:cardElevation="1dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <View
                android:layout_width="4dp"
                android:layout_height="16dp"
                android:background="@color/primary_blue"
                android:backgroundTint="?attr/colorPrimary"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvRowNumber"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bike #1"
                android:textColor="?attr/colorPrimary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-bold"
                android:textStyle="bold"/>

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_info"
                app:tint="?attr/colorOnSurfaceVariant"/>
        </LinearLayout>

        <!-- Chassis Number -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chassis Number"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/etChassisInput"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input_rounded"
                    android:backgroundTint="?attr/colorSurfaceVariant"
                    android:hint="Enter Chassis Number"
                    android:textColor="?attr/colorOnSurface"
                    android:textColorHint="?attr/colorOnSurfaceVariant"
                    android:paddingHorizontal="16dp"
                    android:textSize="15sp"
                    android:inputType="textCapCharacters"
                    android:singleLine="true"
                    android:layout_marginEnd="10dp"/>

                <FrameLayout
                    android:id="@+id/btnScanChassisRow"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_input_rounded"
                    android:backgroundTint="?attr/colorSecondaryContainer"
                    android:clickable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_barcode_scanner"
                        app:tint="?attr/colorOnSecondaryContainer"/>
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Engine Number -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Engine Number"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/etEngineInput"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input_rounded"
                    android:backgroundTint="?attr/colorSurfaceVariant"
                    android:hint="Enter Engine Number"
                    android:textColor="?attr/colorOnSurface"
                    android:textColorHint="?attr/colorOnSurfaceVariant"
                    android:paddingHorizontal="16dp"
                    android:textSize="15sp"
                    android:inputType="textCapCharacters"
                    android:singleLine="true"
                    android:layout_marginEnd="10dp"/>

                <FrameLayout
                    android:id="@+id/btnScanEngineRow"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_input_rounded"
                    android:backgroundTint="?attr/colorSecondaryContainer"
                    android:clickable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_barcode_scanner"
                        app:tint="?attr/colorOnSecondaryContainer"/>
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
