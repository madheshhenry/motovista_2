<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:overScrollMode="never"
        app:layout_constraintBottom_toTopOf="@+id/topBorder"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_hero_subtle"
                android:paddingBottom="24dp">

                <!-- Tighter Premium Header -->
                <RelativeLayout
                    android:id="@+id/premiumHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="24dp"
                    android:paddingTop="20dp"
                    android:clipToPadding="false">

                    <LinearLayout
                        android:id="@+id/profileContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true">

                        <androidx.cardview.widget.CardView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="?attr/colorPrimaryContainer">
                            <ImageView
                                android:id="@+id/ivUserProfile"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_person"
                                app:tint="?attr/colorOnPrimaryContainer"
                                android:padding="6dp"
                                android:scaleType="centerCrop" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Good Morning,"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif-medium" />
                            <TextView
                                android:id="@+id/tvWelcome"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hello, max"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-black" />
                        </LinearLayout>
                    </LinearLayout>

                    <androidx.cardview.widget.CardView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="?attr/colorSurface">
                        <ImageView
                            android:id="@+id/btnNotifications"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_notifications"
                            app:tint="?attr/colorOnSurface"
                            android:padding="10dp"
                            android:foreground="?attr/selectableItemBackgroundBorderless" />
                    </androidx.cardview.widget.CardView>
                </RelativeLayout>

                <!-- Tighter Hero Text -->
                <LinearLayout
                    android:id="@+id/heroTextLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_below="@id/premiumHeader"
                    android:paddingHorizontal="24dp"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DISCOVER YOUR"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Perfect Ride"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="34sp"
                        android:fontFamily="sans-serif-black"
                        android:lineSpacingExtra="-6dp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

            </RelativeLayout>

            <!-- Quick Action Cards Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="18dp"
                android:layout_marginTop="16dp"
                android:clipToPadding="false"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:id="@+id/cardTestRide"
                    android:layout_width="0dp"
                    android:layout_height="84dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="6dp"
                    android:background="@drawable/bg_quick_action"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:foreground="?attr/selectableItemBackground"
                    android:elevation="6dp">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_two_wheeler"
                        app:tint="?attr/colorPrimary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Test Ride"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-bold"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardService"
                    android:layout_width="0dp"
                    android:layout_height="84dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="6dp"
                    android:background="@drawable/bg_quick_action"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:foreground="?attr/selectableItemBackground"
                    android:elevation="6dp">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_motorcycle"
                        app:tint="?attr/colorPrimary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="My Bikes"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-bold"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardRequestBike"
                    android:layout_width="0dp"
                    android:layout_height="84dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="6dp"
                    android:background="@drawable/bg_quick_action"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:foreground="?attr/selectableItemBackground"
                    android:elevation="6dp">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_add_circle"
                        app:tint="?attr/colorPrimary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Request"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-bold"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Top Recommended"
                android:textColor="?attr/colorOnSurface"
                android:textSize="20sp"
                android:fontFamily="sans-serif-black"
                android:layout_marginTop="24dp"
                android:layout_marginStart="24dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvShuffledBikes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingHorizontal="16dp"
                android:clipToPadding="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <LinearLayout
                android:id="@+id/brandSectionsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.cardview.widget.CardView
        android:id="@+id/btnChatBot"
        android:layout_width="56dp"
        android:layout_height="56dp"
        app:cardCornerRadius="28dp"
        app:cardBackgroundColor="?attr/colorPrimary"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toTopOf="@+id/topBorder"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        android:foreground="?attr/selectableItemBackground">
        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_smart_toy"
            app:tint="?attr/colorOnPrimary" />
    </androidx.cardview.widget.CardView>

    <View
        android:id="@+id/topBorder"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutlineVariant"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation" />

    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="?attr/colorSurface"
        android:orientation="horizontal"
        android:elevation="8dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/tabHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:foreground="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:id="@+id/ivHome"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home_filled"
                app:tint="?attr/colorPrimary" />
            <TextView
                android:id="@+id/tvHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="?attr/colorPrimary"
                android:textSize="11sp"
                android:fontFamily="sans-serif-bold"
                android:layout_marginTop="3dp" />
            <View
                android:id="@+id/dotHome"
                android:layout_width="16dp"
                android:layout_height="4dp"
                android:background="@drawable/bg_active_pill"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabBikes"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:foreground="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:id="@+id/ivBikes"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_two_wheeler"
                app:tint="?attr/colorOutline" />
            <TextView
                android:id="@+id/tvBikes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bikes"
                android:textColor="?attr/colorOutline"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="3dp" />
            <View
                android:id="@+id/dotBikes"
                android:layout_width="16dp"
                android:layout_height="4dp"
                android:visibility="invisible" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabEmiCalculator"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:foreground="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:id="@+id/ivEmiCalculator"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_calculate"
                app:tint="?attr/colorOutline" />
            <TextView
                android:id="@+id/tvEmiCalculator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMI"
                android:textColor="?attr/colorOutline"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="3dp" />
            <View
                android:id="@+id/dotEmiCalculator"
                android:layout_width="16dp"
                android:layout_height="4dp"
                android:visibility="invisible" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabOrders"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:foreground="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:id="@+id/ivOrders"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_receipt_long"
                app:tint="?attr/colorOutline" />
            <TextView
                android:id="@+id/tvOrders"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Orders"
                android:textColor="?attr/colorOutline"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="3dp" />
            <View
                android:id="@+id/dotOrders"
                android:layout_width="16dp"
                android:layout_height="4dp"
                android:visibility="invisible" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:foreground="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:id="@+id/ivProfile"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_person"
                app:tint="?attr/colorOutline" />
            <TextView
                android:id="@+id/tvProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textColor="?attr/colorOutline"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="3dp" />
            <View
                android:id="@+id/dotProfile"
                android:layout_width="16dp"
                android:layout_height="4dp"
                android:visibility="invisible" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>