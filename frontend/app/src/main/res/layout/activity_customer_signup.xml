<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp"
        android:background="?attr/colorSurface"
        android:elevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="?attr/colorOnSurface"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/create_account"
            android:textColor="?attr/colorOnSurface"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:fontFamily="sans-serif-medium" />

        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/headerLayout">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingVertical="32dp">

            <LinearLayout
                android:id="@+id/formContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/full_name_label"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-bold"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_premium_input_container"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="20dp">
                    
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_person"
                        app:tint="?attr/colorOnSurfaceVariant"
                        android:layout_marginEnd="12dp" />

                    <EditText
                        android:id="@+id/etFullName"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="@string/full_name_hint"
                        android:textColor="?attr/colorOnSurface"
                        android:textColorHint="?attr/colorOutline"
                        android:textSize="16sp"
                        android:background="@null"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:inputType="textPersonName" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Email Address"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-bold"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_premium_input_container"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="20dp">
                    
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_email"
                        app:tint="?attr/colorOnSurfaceVariant"
                        android:layout_marginEnd="12dp" />

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="Enter your email address"
                        android:textColor="?attr/colorOnSurface"
                        android:textColorHint="?attr/colorOutline"
                        android:textSize="16sp"
                        android:background="@null"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:inputType="textEmailAddress" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Phone Number"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-bold"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_premium_input_container"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="20dp">
                    
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_phone"
                        app:tint="?attr/colorOnSurfaceVariant"
                        android:layout_marginEnd="12dp" />

                    <EditText
                        android:id="@+id/etPhone"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="Enter your phone number"
                        android:textColor="?attr/colorOnSurface"
                        android:textColorHint="?attr/colorOutline"
                        android:textSize="16sp"
                        android:background="@null"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:inputType="phone" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-bold"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_premium_input_container"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="6dp">
                    
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_lock"
                        app:tint="?attr/colorOnSurfaceVariant"
                        android:layout_marginEnd="12dp" />

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Create a password"
                        android:textColor="?attr/colorOnSurface"
                        android:textColorHint="?attr/colorOutline"
                        android:textSize="16sp"
                        android:background="@null"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:inputType="textPassword" />

                    <ImageView
                        android:id="@+id/btnTogglePassword"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_visibility_off"
                        app:tint="?attr/colorOnSurfaceVariant"
                        android:padding="4dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/password_length_tip"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="20dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Confirm Password"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-bold"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_premium_input_container"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="24dp">
                    
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_lock"
                        app:tint="?attr/colorOnSurfaceVariant"
                        android:layout_marginEnd="12dp" />

                    <EditText
                        android:id="@+id/etConfirmPassword"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Confirm your password"
                        android:textColor="?attr/colorOnSurface"
                        android:textColorHint="?attr/colorOutline"
                        android:textSize="16sp"
                        android:background="@null"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:inputType="textPassword" />

                    <ImageView
                        android:id="@+id/btnToggleConfirmPassword"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_visibility_off"
                        app:tint="?attr/colorOnSurfaceVariant"
                        android:padding="4dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/termsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="32dp">

                    <CheckBox
                        android:id="@+id/cbTerms"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="?attr/colorPrimary"
                        android:background="?attr/selectableItemBackgroundBorderless" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/terms_agreement"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

            </LinearLayout>

            <Button
                android:id="@+id/btnSignUp"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:text="@string/sign_up"
                android:textColor="?attr/colorOnPrimary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-bold"
                android:background="@drawable/bg_premium_primary_btn"
                android:elevation="6dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/formContainer" />

            <LinearLayout
                android:id="@+id/loginLinkContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="32dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btnSignUp">

                <TextView
                    android:id="@+id/tvLoginLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Log in"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-bold"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>