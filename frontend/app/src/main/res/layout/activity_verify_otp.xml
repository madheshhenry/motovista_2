<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="48dp">

            <!-- Back Button -->
            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="?attr/colorOnBackground"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginStart="-12dp"
                android:layout_marginTop="8dp" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Verify OTP"
                android:textColor="?attr/colorOnBackground"
                android:textSize="32sp"
                android:fontFamily="sans-serif-black"
                android:layout_marginTop="40dp" />

            <TextView
                android:id="@+id/tv_instruction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter the 6-digit code sent to your email address."
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="4dp" />

            <!-- OTP Input Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="48dp"
                android:gravity="center">

                <EditText
                    android:id="@+id/et_otp1"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_premium_input_container"
                    android:gravity="center"
                    android:inputType="number"
                    android:maxLength="1"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-bold"
                    android:layout_marginHorizontal="4dp" />

                <EditText
                    android:id="@+id/et_otp2"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_premium_input_container"
                    android:gravity="center"
                    android:inputType="number"
                    android:maxLength="1"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-bold"
                    android:layout_marginHorizontal="4dp" />

                <EditText
                    android:id="@+id/et_otp3"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_premium_input_container"
                    android:gravity="center"
                    android:inputType="number"
                    android:maxLength="1"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-bold"
                    android:layout_marginHorizontal="4dp" />

                <EditText
                    android:id="@+id/et_otp4"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_premium_input_container"
                    android:gravity="center"
                    android:inputType="number"
                    android:maxLength="1"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-bold"
                    android:layout_marginHorizontal="4dp" />

                <EditText
                    android:id="@+id/et_otp5"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_premium_input_container"
                    android:gravity="center"
                    android:inputType="number"
                    android:maxLength="1"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-bold"
                    android:layout_marginHorizontal="4dp" />

                <EditText
                    android:id="@+id/et_otp6"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_premium_input_container"
                    android:gravity="center"
                    android:inputType="number"
                    android:maxLength="1"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-bold"
                    android:layout_marginHorizontal="4dp" />

            </LinearLayout>

            <!-- Reset Password Button -->
            <Button
                android:id="@+id/btn_verify_otp"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Verify Code"
                android:textColor="?attr/colorOnPrimary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-bold"
                android:background="@drawable/bg_premium_primary_btn"
                android:elevation="6dp"
                android:layout_marginTop="56dp" />

            <!-- Resend Link -->
            <TextView
                android:id="@+id/tv_resend_otp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Didn't receive the code? Resend"
                android:textColor="?attr/colorPrimary"
                android:textSize="15sp"
                android:fontFamily="sans-serif-bold"
                android:layout_gravity="center"
                android:padding="12dp"
                android:layout_marginTop="24dp" />

        </LinearLayout>

    </ScrollView>

    <ProgressBar
        android:id="@+id/loading_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="?attr/colorPrimary"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
