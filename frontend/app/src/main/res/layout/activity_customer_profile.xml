<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/charcoal_dark"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/root_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <!-- Background Glow Effect -->
        <View
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:background="@drawable/bg_hero_glow"
            android:alpha="0.4"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="-150dp"
            android:layout_marginTop="-150dp" />

        <!-- Header -->
        <LinearLayout
            android:id="@+id/header_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="60dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circle_midnight"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="sans-serif-black"
                android:text="Complete Profile"
                android:textColor="@color/white"
                android:textSize="32sp" />

            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:alpha="0.7"
                android:fontFamily="sans-serif-medium"
                android:text="Secure your account for bookings"
                android:textColor="@color/white"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Profile Photo -->
        <RelativeLayout
            android:id="@+id/profile_photo_section"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/header_section">

            <FrameLayout
                android:id="@+id/profileImageContainer"
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:padding="4dp"
                android:background="@drawable/bg_circle_gradient">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardCornerRadius="65dp"
                    app:cardBackgroundColor="@color/charcoal_light"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/profileImagePlaceholder"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_camera"
                        app:tint="@color/brand_primary" />
                </androidx.cardview.widget.CardView>
            </FrameLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/btnAddPhoto"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignBottom="@id/profileImageContainer"
                android:layout_alignEnd="@id/profileImageContainer"
                app:cardBackgroundColor="@color/brand_primary"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_add"
                    app:tint="@color/charcoal_dark" />
            </androidx.cardview.widget.CardView>
        </RelativeLayout>

        <TextView
            android:id="@+id/btnAddPhotoText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Photo"
            android:textColor="@color/brand_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-bold"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/profile_photo_section"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Form Section -->
        <LinearLayout
            android:id="@+id/form_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/btnAddPhotoText">

            <!-- DOB -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATE OF BIRTH"
                android:textColor="@color/brand_primary"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-black"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/container_dob"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_glass_input"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <EditText
                    android:id="@+id/etDOB"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:focusable="false"
                    android:hint="DD / MM / YYYY"
                    android:textColor="@color/white"
                    android:textColorHint="@color/gray_500" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="@color/brand_primary" />
            </LinearLayout>

            <!-- Address -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="RESIDENTIAL ADDRESS"
                android:textColor="@color/brand_primary"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-black"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etHouseNo"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_glass_input"
                android:hint="House / Flat No."
                android:paddingHorizontal="16dp"
                android:textColor="@color/white"
                android:textColorHint="@color/gray_500" />

            <EditText
                android:id="@+id/etStreet"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_glass_input"
                android:hint="Street / Locality"
                android:paddingHorizontal="16dp"
                android:textColor="@color/white"
                android:textColorHint="@color/gray_500" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etCity"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_glass_input"
                    android:hint="City"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/gray_500" />

                <EditText
                    android:id="@+id/etState"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_glass_input"
                    android:hint="State"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/gray_500" />
            </LinearLayout>

            <EditText
                android:id="@+id/etPincode"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_glass_input"
                android:hint="Pincode"
                android:inputType="number"
                android:paddingHorizontal="16dp"
                android:textColor="@color/white"
                android:textColorHint="@color/gray_500" />

            <!-- ID Proof -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="IDENTITY VERIFICATION"
                android:textColor="@color/brand_primary"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-black"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/btnAadharFront"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_glass_input"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_upload"
                        app:tint="@color/brand_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Aadhar Front"
                        android:textColor="@color/gray_400"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnAadharBack"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_glass_input"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_upload"
                        app:tint="@color/brand_primary" />

                    <TextView
                        android:id="@+id/tv_pan_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="PAN Card"
                        android:textColor="@color/gray_400"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Submit Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCompleteSetup"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="40dp"
                android:background="@drawable/bg_gradient_button"
                app:backgroundTint="@null"
                android:fontFamily="sans-serif-black"
                android:text="FINISH SETUP"
                android:textAllCaps="true"
                android:textColor="@color/charcoal_dark"
                android:textSize="18sp"
                app:cornerRadius="16dp" />

            <TextView
                android:id="@+id/btnSkip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:fontFamily="sans-serif-bold"
                android:padding="12dp"
                android:text="SKIP FOR NOW"
                android:textColor="@color/gray_500"
                android:textSize="14sp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>