<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/charcoal_dark"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/root_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Top Header Section -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_circle_midnight"
            android:padding="14dp"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="sans-serif-black"
            android:text="Complete Your Profile"
            android:textColor="@color/white"
            android:textSize="28sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnBack" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif-medium"
            android:text="Finish setting up your account"
            android:textColor="@color/gray_400"
            android:textSize="16sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title" />

        <!-- Profile Photo Section -->
        <RelativeLayout
            android:id="@+id/profile_photo_section"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle">

            <FrameLayout
                android:id="@+id/profileImageContainer"
                android:layout_width="120dp"
                android:layout_height="120dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_circle_midnight" />

                <ImageView
                    android:id="@+id/profileImagePlaceholder"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_camera"
                    app:tint="@color/gray_500" />
            </FrameLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/btnAddPhoto"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignBottom="@id/profileImageContainer"
                android:layout_alignEnd="@id/profileImageContainer"
                app:cardBackgroundColor="@color/primary"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_add"
                    app:tint="@color/white" />
            </androidx.cardview.widget.CardView>
        </RelativeLayout>

        <TextView
            android:id="@+id/btnAddPhotoText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="sans-serif-bold"
            android:text="Add Photo"
            android:textColor="@color/primary"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/profile_photo_section" />

        <!-- Date of Birth Section -->
        <TextView
            android:id="@+id/label_dob"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="sans-serif-medium"
            android:text="Date of Birth"
            android:textColor="@color/gray_300"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnAddPhotoText" />

        <LinearLayout
            android:id="@+id/container_dob"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_premium_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toBottomOf="@id/label_dob">

            <EditText
                android:id="@+id/etDOB"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:focusable="false"
                android:hint="DD/MM/YYYY"
                android:textColor="@color/white"
                android:textColorHint="@color/gray_500"
                android:textSize="16sp" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_calendar"
                app:tint="@color/primary" />
        </LinearLayout>

        <!-- Address Section -->
        <TextView
            android:id="@+id/label_address"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="sans-serif-medium"
            android:text="Residential Address"
            android:textColor="@color/gray_300"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/container_dob" />

        <EditText
            android:id="@+id/etHouseNo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_premium_input"
            android:hint="House / Flat No."
            android:paddingHorizontal="16dp"
            android:textColor="@color/white"
            android:textColorHint="@color/gray_500"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/label_address" />

        <EditText
            android:id="@+id/etStreet"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_premium_input"
            android:hint="Street / Locality"
            android:paddingHorizontal="16dp"
            android:textColor="@color/white"
            android:textColorHint="@color/gray_500"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/etHouseNo" />

        <LinearLayout
            android:id="@+id/city_state_row"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/etStreet">

            <EditText
                android:id="@+id/etCity"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_premium_input"
                android:hint="City"
                android:paddingHorizontal="16dp"
                android:textColor="@color/white"
                android:textColorHint="@color/gray_500"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/etState"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_premium_input"
                android:hint="State"
                android:paddingHorizontal="16dp"
                android:textColor="@color/white"
                android:textColorHint="@color/gray_500"
                android:textSize="16sp" />
        </LinearLayout>

        <EditText
            android:id="@+id/etPincode"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_premium_input"
            android:hint="Pincode"
            android:inputType="number"
            android:paddingHorizontal="16dp"
            android:textColor="@color/white"
            android:textColorHint="@color/gray_500"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/city_state_row" />

        <!-- Documents Section -->
        <TextView
            android:id="@+id/label_documents"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="sans-serif-medium"
            android:text="Verification Documents"
            android:textColor="@color/gray_300"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/etPincode" />

        <LinearLayout
            android:id="@+id/aadhar_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/label_documents">

            <LinearLayout
                android:id="@+id/btnAadharFront"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_upload_premium"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_upload"
                    app:tint="@color/primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Aadhar Front"
                    android:textColor="@color/gray_400"
                    android:textSize="12dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnAadharBack"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_upload_premium"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_upload"
                    app:tint="@color/primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Aadhar Back"
                    android:textColor="@color/gray_400"
                    android:textSize="12dp" />
            </LinearLayout>
        </LinearLayout>

        <EditText
            android:id="@+id/etPAN"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_premium_input"
            android:hint="PAN Card Number"
            android:paddingHorizontal="16dp"
            android:textColor="@color/white"
            android:textColorHint="@color/gray_500"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/aadhar_row" />

        <!-- Confirm Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCompleteSetup"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="40dp"
            android:backgroundTint="@color/primary"
            android:fontFamily="sans-serif-bold"
            android:text="Complete Profile Setup"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:cornerRadius="16dp"
            app:layout_constraintTop_toBottomOf="@id/etPAN" />

        <TextView
            android:id="@+id/btnSkip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="24dp"
            android:fontFamily="sans-serif-medium"
            android:padding="12dp"
            android:text="Skip For Now"
            android:textColor="@color/gray_500"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnCompleteSetup" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>