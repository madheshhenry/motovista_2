<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp"
        android:gravity="center_vertical"
        android:background="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/text_primary_light"
            android:background="?selectableItemBackgroundBorderless"
            android:padding="8dp" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sales History"
            android:textColor="@color/text_primary_light"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center" />

        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />

    </LinearLayout>

    <!-- Filters Container -->
    <HorizontalScrollView
        android:id="@+id/filterContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="16dp"
        android:background="@color/white"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="8dp">

            <Button
                android:id="@+id/btnFilterAll"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="All"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:background="@drawable/primary_button_rounded"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnFilterCash"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Cash"
                android:textAllCaps="false"
                android:textColor="@color/text_primary_light"
                android:textSize="13sp"
                android:background="@drawable/gray_button_rounded"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnFilterEMI"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="EMI"
                android:textAllCaps="false"
                android:textColor="@color/text_primary_light"
                android:textSize="13sp"
                android:background="@drawable/gray_button_rounded"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnFilterThisMonth"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="This Month"
                android:textAllCaps="false"
                android:textColor="@color/text_primary_light"
                android:textSize="13sp"
                android:background="@drawable/gray_button_rounded" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Sales List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerSalesHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/filterContainer"
        app:layout_constraintBottom_toBottomOf="parent"
        android:paddingTop="8dp"
        android:clipToPadding="false" />

    <!-- Empty State -->
    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No sales records found"
        android:textColor="@color/gray_400"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/filterContainer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>