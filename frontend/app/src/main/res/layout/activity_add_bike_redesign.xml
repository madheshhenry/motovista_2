<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground"
    tools:context=".AddBikeActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="?attr/actionBarSize"
            android:paddingTop="20dp"
            android:background="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="Add New Bike"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="40dp" />

            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutlineVariant" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="132dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- SECTION 1: BIKE MODEL DETAILS -->
            <com.google.android.material.card.MaterialCardView
                style="@style/MaterialCardViewStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="Bike Model Details"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Shared specifications for all variants"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Form Grid -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:baselineAligned="false"
                            android:orientation="horizontal">

                            <!-- BRAND -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    style="@style/LabelText"
                                    android:text="Brand" />

                                <LinearLayout
                                    style="@style/InputContainer"
                                    android:orientation="horizontal">

                                    <ImageView
                                        style="@style/InputIcon"
                                        android:src="@drawable/ic_sell" />

                                    <EditText
                                        android:id="@+id/etBrand"
                                        style="@style/InputEditText"
                                        android:hint="e.g. Brand" />
                                </LinearLayout>
                            </LinearLayout>

                            <!-- MODEL NAME -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    style="@style/LabelText"
                                    android:text="Model Name" />

                                <LinearLayout
                                    style="@style/InputContainer"
                                    android:orientation="horizontal">

                                    <ImageView
                                        style="@style/InputIcon"
                                        android:src="@drawable/ic_motorcycle" />

                                    <EditText
                                        android:id="@+id/etModelName"
                                        style="@style/InputEditText"
                                        android:hint="e.g. Model X" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- ROW 2 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:baselineAligned="false"
                            android:orientation="horizontal">

                            <!-- YEAR -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    style="@style/LabelText"
                                    android:text="Model Year" />

                                <LinearLayout
                                    style="@style/InputContainer"
                                    android:orientation="horizontal">

                                    <ImageView
                                        style="@style/InputIcon"
                                        android:src="@drawable/ic_calendar" />

                                    <EditText
                                        android:id="@+id/etYear"
                                        style="@style/InputEditText"
                                        android:hint="2024"
                                        android:inputType="number" />
                                </LinearLayout>
                            </LinearLayout>

                            <!-- ENGINE -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    style="@style/LabelText"
                                    android:text="Engine CC" />

                                <LinearLayout
                                    style="@style/InputContainer"
                                    android:orientation="horizontal">

                                    <ImageView
                                        style="@style/InputIcon"
                                        android:src="@drawable/ic_settings_input" />

                                    <EditText
                                        android:id="@+id/etEngineCC"
                                        style="@style/InputEditText"
                                        android:hint="150cc" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- ROW 3: Types -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:baselineAligned="false"
                            android:orientation="horizontal">

                            <!-- Fuel Type -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    style="@style/LabelText"
                                    android:text="Fuel Type" />

                                <Spinner
                                    android:id="@+id/spFuelType"
                                    style="@style/SimpleSpinner" />
                            </LinearLayout>

                            <!-- Transmission -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    style="@style/LabelText"
                                    android:text="Transmission" />

                                <Spinner
                                    android:id="@+id/spTransmission"
                                    style="@style/SimpleSpinner" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- ROW 4 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:baselineAligned="false"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    style="@style/LabelText"
                                    android:text="Mileage" />

                                <EditText
                                    android:id="@+id/etMileage"
                                    style="@style/SimpleInput"
                                    android:hint="45 kmpl" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    style="@style/LabelText"
                                    android:text="Fuel Tank" />

                                <EditText
                                    android:id="@+id/etFuelTank"
                                    style="@style/SimpleInput"
                                    android:hint="12 L" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- ROW 5 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:baselineAligned="false"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    style="@style/LabelText"
                                    android:text="Kerb Weight" />

                                <EditText
                                    android:id="@+id/etKerbWeight"
                                    style="@style/SimpleInput"
                                    android:hint="140 kg" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    style="@style/LabelText"
                                    android:text="Seat Height" />

                                <EditText
                                    android:id="@+id/etSeatHeight"
                                    style="@style/SimpleInput"
                                    android:hint="790 mm" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- ROW 6 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:baselineAligned="false"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    style="@style/LabelText"
                                    android:text="Max Torque" />

                                <EditText
                                    android:id="@+id/etMaxTorque"
                                    style="@style/SimpleInput"
                                    android:hint="13 Nm" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    style="@style/LabelText"
                                    android:text="Max Power" />

                                <EditText
                                    android:id="@+id/etMaxPower"
                                    style="@style/SimpleInput"
                                    android:hint="15 hp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Width Full: Ground Clearance -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="vertical">

                            <TextView
                                style="@style/LabelText"
                                android:text="Ground Clearance" />

                            <EditText
                                android:id="@+id/etGroundClearance"
                                style="@style/SimpleInput"
                                android:hint="165 mm" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- SECTION HEADER: VARIANT BUILDER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="Variant Builder"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Variant Builder Section (Dynamic) -->
            <TextView
                style="@style/LabelText"
                android:layout_marginTop="12dp"
                android:text="VARIANTS"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/variantsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddVariant"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="+ Add Another Variant"
                android:textColor="?attr/colorPrimary"
                app:cornerRadius="28dp"
                android:textAllCaps="false" />

            <!-- INVOICE DETAILS HEADER -->
            <TextView
                style="@style/LabelText"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="INVOICE DETAILS"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp" />

            <!-- Warranty & Services -->
            <com.google.android.material.card.MaterialCardView
                style="@style/MaterialCardViewStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="Warranty &amp; Services"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/LabelText"
                                android:text="Warranty (Years)" />

                            <LinearLayout style="@style/InputContainer">
                                <ImageView
                                    style="@style/InputIcon"
                                    android:src="@drawable/ic_verified_user" />

                                <EditText
                                    android:id="@+id/etWarranty"
                                    style="@style/InputEditText"
                                    android:hint="e.g. 5 Years"
                                    android:inputType="text|number" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/LabelText"
                                android:text="Free Services" />

                            <LinearLayout style="@style/InputContainer">
                                <ImageView
                                    style="@style/InputIcon"
                                    android:src="@drawable/ic_build_circle" />

                                <EditText
                                    android:id="@+id/etFreeServices"
                                    style="@style/InputEditText"
                                    android:hint="e.g. 3"
                                    android:inputType="number" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- FITTINGS SECTION -->
            <com.google.android.material.card.MaterialCardView
                style="@style/MaterialCardViewStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/llFittingsSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="vertical">
                
                <TextView
                    style="@style/LabelText"
                    android:text="Mandatory Fittings"
                    android:textColor="?attr/colorOnSurface" />
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_rounded"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp"
                    android:padding="16dp">

                    <CheckBox android:id="@+id/cbCrashBar" android:text="Crash Bar" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp"/>
                    <CheckBox android:id="@+id/cbSareeGuard" android:text="Saree Guard" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp"/>
                    <CheckBox android:id="@+id/cbMirror" android:text="Mirror Set" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp"/>
                    <CheckBox android:id="@+id/cbNumberPlate" android:text="Front &amp; Rear Number Plate" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp"/>
                    <CheckBox android:id="@+id/cbSideStand" android:text="Side Stand" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp"/>
                    <CheckBox android:id="@+id/cbFootRest" android:text="Foot Rest" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp"/>
                </LinearLayout>

                <!-- Additional Fittings Section -->
                <TextView
                    style="@style/LabelText"
                    android:layout_marginTop="24dp"
                    android:text="Additional Fittings (Optional)"
                    android:textColor="?attr/colorOnSurface" />
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_rounded"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp"
                    android:padding="16dp">

                    <!-- Side Box -->
                    <LinearLayout android:orientation="horizontal" android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp">
                        <CheckBox android:id="@+id/cbSideBox" android:text="Side Box (Fibre)" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
                        <EditText android:id="@+id/etSideBoxPrice" android:hint="0" android:inputType="number" android:layout_width="80dp" android:layout_height="40dp" android:background="@drawable/bg_input_rounded" android:padding="8dp" android:textSize="12sp" android:textColor="?attr/colorOnSurface"/>
                    </LinearLayout>
                    
                    <!-- Petrol Tank Bag -->
                    <LinearLayout android:orientation="horizontal" android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp">
                        <CheckBox android:id="@+id/cbPetrolTankBag" android:text="Petrol Tank Bag" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
                        <EditText android:id="@+id/etPetrolTankBagPrice" android:hint="0" android:inputType="number" android:layout_width="80dp" android:layout_height="40dp" android:background="@drawable/bg_input_rounded" android:padding="8dp" android:textSize="12sp" android:textColor="?attr/colorOnSurface"/>
                    </LinearLayout>
                    
                    <!-- Grip Cover -->
                    <LinearLayout android:orientation="horizontal" android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp">
                        <CheckBox android:id="@+id/cbGripCover" android:text="Grip Cover" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
                        <EditText android:id="@+id/etGripCoverPrice" android:hint="0" android:inputType="number" android:layout_width="80dp" android:layout_height="40dp" android:background="@drawable/bg_input_rounded" android:padding="8dp" android:textSize="12sp" android:textColor="?attr/colorOnSurface"/>
                    </LinearLayout>
                    
                    <!-- Bag Hook -->
                    <LinearLayout android:orientation="horizontal" android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp">
                        <CheckBox android:id="@+id/cbBagHook" android:text="Bag Hook" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
                        <EditText android:id="@+id/etBagHookPrice" android:hint="0" android:inputType="number" android:layout_width="80dp" android:layout_height="40dp" android:background="@drawable/bg_input_rounded" android:padding="8dp" android:textSize="12sp" android:textColor="?attr/colorOnSurface"/>
                    </LinearLayout>
                    
                    <!-- Helmet (Free) -->
                    <LinearLayout android:orientation="horizontal" android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp">
                        <CheckBox android:id="@+id/cbHelmet" android:text="Helmet" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
                        <TextView android:text="FREE" android:layout_width="80dp" android:layout_height="wrap_content" android:background="@drawable/bg_input_rounded" android:backgroundTint="?attr/colorPrimaryContainer" android:textColor="?attr/colorPrimary" android:gravity="center" android:padding="8dp" android:textSize="10sp" android:textStyle="bold"/>
                    </LinearLayout>
                    
                    <!-- Body Cover -->
                    <LinearLayout android:orientation="horizontal" android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp">
                        <CheckBox android:id="@+id/cbBodyCover" android:text="Body Cover (Full)" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
                        <EditText android:id="@+id/etBodyCoverPrice" android:hint="0" android:inputType="number" android:layout_width="80dp" android:layout_height="40dp" android:background="@drawable/bg_input_rounded" android:padding="8dp" android:textSize="12sp" android:textColor="?attr/colorOnSurface"/>
                    </LinearLayout>
                    
                    <!-- Indicator Buzzer -->
                    <LinearLayout android:orientation="horizontal" android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp">
                        <CheckBox android:id="@+id/cbIndicatorBuzzer" android:text="Indicator Buzzer" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
                        <EditText android:id="@+id/etIndicatorBuzzerPrice" android:hint="0" android:inputType="number" android:layout_width="80dp" android:layout_height="40dp" android:background="@drawable/bg_input_rounded" android:padding="8dp" android:textSize="12sp" android:textColor="?attr/colorOnSurface"/>
                    </LinearLayout>
                    
                    <!-- Seat Cover -->
                    <LinearLayout android:orientation="horizontal" android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp">
                        <CheckBox android:id="@+id/cbSeatCover" android:text="Seat Cover" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
                        <EditText android:id="@+id/etSeatCoverPrice" android:hint="0" android:inputType="number" android:layout_width="80dp" android:layout_height="40dp" android:background="@drawable/bg_input_rounded" android:padding="8dp" android:textSize="12sp" android:textColor="?attr/colorOnSurface"/>
                    </LinearLayout>
                    
                    <!-- Ladies Handle -->
                    <LinearLayout android:orientation="horizontal" android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp">
                        <CheckBox android:id="@+id/cbLadiesHandle" android:text="Ladies Handle" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
                        <EditText android:id="@+id/etLadiesHandlePrice" android:hint="0" android:inputType="number" android:layout_width="80dp" android:layout_height="40dp" android:background="@drawable/bg_input_rounded" android:padding="8dp" android:textSize="12sp" android:textColor="?attr/colorOnSurface"/>
                    </LinearLayout>
                    
                    <!-- Engine Guard -->
                    <LinearLayout android:orientation="horizontal" android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp">
                        <CheckBox android:id="@+id/cbEngineGuard" android:text="Engine Guard" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
                        <EditText android:id="@+id/etEngineGuardPrice" android:hint="0" android:inputType="number" android:layout_width="80dp" android:layout_height="40dp" android:background="@drawable/bg_input_rounded" android:padding="8dp" android:textSize="12sp" android:textColor="?attr/colorOnSurface"/>
                    </LinearLayout>
                    
                    <!-- Bumper SS -->
                    <LinearLayout android:orientation="horizontal" android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp">
                        <CheckBox android:id="@+id/cbBumperSS" android:text="Bumper SS" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
                        <EditText android:id="@+id/etBumperSSPrice" android:hint="0" android:inputType="number" android:layout_width="80dp" android:layout_height="40dp" android:background="@drawable/bg_input_rounded" android:padding="8dp" android:textSize="12sp" android:textColor="?attr/colorOnSurface"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- Custom Additional Fittings Container -->
                <LinearLayout
                    android:id="@+id/llAdditionalFittings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddAdditionalFitting"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:drawableStart="@drawable/ic_add"
                    android:text="Add Custom Fitting"
                    android:textColor="?attr/colorPrimary" />

            </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Invoice Legal Notes -->
            <com.google.android.material.card.MaterialCardView
                style="@style/MaterialCardViewStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="Invoice Legal Notes"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        style="@style/LabelText"
                        android:text="Registration &amp; Address Proof"
                        android:textColor="?attr/colorOnSurface" />
                    
                    <TextView
                        android:id="@+id/etRegProof"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input_rounded"
                        android:padding="12dp"
                        android:text="For registration purpose any one of the following is required in ORIGINAL &amp; XEROX for Address Proof: Aadhar Card, LIC Policy, Passport, GST, Voter ID, PAN Card"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        style="@style/LabelText"
                        android:text="Price Disclaimer"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/etPriceDisclaimer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input_rounded"
                        android:padding="12dp"
                        android:text="Price &amp; taxes ruling at the time of delivery will be applicable."
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FOOTER -->
    <LinearLayout
        android:id="@+id/footerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginTop="12dp"
        android:background="?attr/colorSurface"
        android:elevation="16dp"
        android:orientation="horizontal"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="CANCEL"
            android:textColor="?attr/colorOnSurface"
            app:cornerRadius="28dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveBike"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="2"
            android:text="Save Bike"
            android:textColor="?attr/colorOnPrimary"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            app:backgroundTint="?attr/colorPrimary"
            app:cornerRadius="28dp"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
