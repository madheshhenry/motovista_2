<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_hero_subtle">

    <!-- Sticky Header -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:gravity="center_vertical"
        android:background="@android:color/transparent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Back Button -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="?attr/colorOnSurface"
            android:padding="12dp"
            android:background="@drawable/bg_circle_ripple"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Back" />

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Order Status"
            android:textColor="?attr/colorOnSurface"
            android:textSize="20sp"
            android:fontFamily="sans-serif-bold"
            android:gravity="center"
            android:layout_marginEnd="48dp" />

    </LinearLayout>

    <!-- Main Content Area -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/headerLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="@dimen/padding_large"
            android:paddingTop="24dp"
            android:paddingBottom="48dp"
            android:clipToPadding="false">

            <!-- =========================
                 STATE 1: INITIAL STATUS
                 ========================= -->
            <LinearLayout
                android:id="@+id/layoutStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Dynamic Status Animation Container -->
                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="24dp"
                    android:layout_gravity="center">

                    <!-- Outer Ring (Color will change dynamically) -->
                    <View
                        android:id="@+id/outerRing"
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        android:layout_centerInParent="true"
                        android:background="@drawable/bg_pulsing_ring" />

                    <!-- Status Icon Container -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardStatusIcon"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_centerInParent="true"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="?attr/colorPrimary">

                        <ImageView
                            android:id="@+id/ivStatusIcon"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="20dp"
                            android:src="@drawable/ic_check_white"
                            android:scaleType="fitCenter"
                            android:contentDescription="Status" />

                    </androidx.cardview.widget.CardView>
                </RelativeLayout>

                <!-- Status Message -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingHorizontal="24dp"
                    android:layout_marginBottom="32dp">

                    <TextView
                        android:id="@+id/tvStatusTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Processing Order"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="24sp"
                        android:fontFamily="sans-serif-black"
                        android:gravity="center"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvStatusMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="We are reviewing your request. Please wait for admin approval."
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="15sp"
                        android:alpha="0.8"
                        android:gravity="center"
                        android:fontFamily="sans-serif-medium"
                        android:lineSpacingExtra="4sp" />

                </LinearLayout>

                <!-- ORDER DETAILS CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardOrderDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:layout_marginBottom="24dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:cardBackgroundColor="?attr/colorSurface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="ORDER DETAILS"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.1"
                            android:paddingBottom="16dp" />

                        <!-- Order ID -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="10dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Order ID"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium" />
                            <TextView
                                android:id="@+id/tvOrderId"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="..."
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-bold" />
                        </LinearLayout>

                        <!-- Bike Name -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="10dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Bike"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium" />
                            <TextView
                                android:id="@+id/tvBikeName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="..."
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-bold"
                                android:maxWidth="200dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:gravity="end"/>
                        </LinearLayout>

                        <!-- Variant -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="10dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Variant"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium" />
                            <TextView
                                android:id="@+id/tvBikeVariant"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="..."
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-bold" />
                        </LinearLayout>

                        <!-- Price -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="10dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Price"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium" />
                            <TextView
                                android:id="@+id/tvBikePrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="..."
                                android:textColor="?attr/colorPrimary"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-black" />
                        </LinearLayout>

                        <!-- Color -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="10dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Color"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium" />
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <View
                                    android:id="@+id/viewBikeColorDot"
                                    android:layout_width="12dp"
                                    android:layout_height="12dp"
                                    android:background="@drawable/circle_dot"
                                    android:layout_marginEnd="8dp"/>
                                <TextView
                                    android:id="@+id/tvBikeColor"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="..."
                                    android:textColor="?attr/colorOnSurface"
                                    android:textSize="14sp"
                                    android:fontFamily="sans-serif-bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Date -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="10dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Request Date"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium" />
                            <TextView
                                android:id="@+id/tvOrderDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="..."
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-bold" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>


            <!-- =========================
                 STATE 2: TRACKING VIEW (Modernized Design)
                 ========================= -->
            <LinearLayout
                android:id="@+id/layoutTracking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="24dp">

                <!-- Tracking Details Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:cardBackgroundColor="?attr/colorSurface"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">
                        
                        <!-- Bike Image Container -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            android:layout_marginEnd="16dp">
                            <ImageView
                                android:id="@+id/ivTrackBikeImage"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/placeholder_bike"
                                android:scaleType="centerCrop"
                                android:background="?attr/colorSurfaceVariant"/>
                        </com.google.android.material.card.MaterialCardView>
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            
                            <!-- Bike Name -->
                            <TextView
                                android:id="@+id/tvTrackBikeName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="..."
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="18sp"
                                android:fontFamily="sans-serif-bold"
                                android:maxLines="1"
                                android:ellipsize="end"/>
                                
                            <!-- Order ID -->
                            <TextView
                                android:id="@+id/tvTrackOrderId"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Order #..."
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="4dp"/>
                                
                            <TextView
                                android:id="@+id/tvTrackOrderDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Placed on ..."
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Order Progress Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:cardBackgroundColor="?attr/colorSurface"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        
                        <!-- Header -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Order Progress"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="16sp"
                            android:fontFamily="sans-serif-black"
                            android:padding="20dp"
                            android:background="@drawable/bg_bottom_border"/>
                            
                         <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">
                            
                            <!-- ITEM 1: Order Confirmed -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:gravity="center_horizontal"
                                    android:layout_marginEnd="16dp">
                                    <ImageView
                                        android:id="@+id/ivStep1Icon"
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:src="@drawable/ic_check_circle"
                                        app:tint="?attr/colorPrimary"/>
                                    <View
                                        android:id="@+id/viewStep1Line"
                                        android:layout_width="2dp"
                                        android:layout_height="48dp"
                                        android:background="?attr/colorPrimary"/>
                                </LinearLayout>
                                
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:paddingBottom="24dp">
                                    <TextView
                                        android:id="@+id/tvStep1Title"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Order Confirmed"
                                        android:textColor="?attr/colorOnSurface"
                                        android:fontFamily="sans-serif-bold"
                                        android:textSize="15sp"/>
                                    <TextView
                                        android:id="@+id/tvStep1Status"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Completed"
                                        android:textColor="?attr/colorOnSurfaceVariant"
                                        android:fontFamily="sans-serif-medium"
                                        android:textSize="13sp"/>
                                </LinearLayout>
                            </LinearLayout>

                            <!-- ITEM 2: Payment Completed -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:gravity="center_horizontal"
                                    android:layout_marginEnd="16dp">
                                    <ImageView
                                        android:id="@+id/ivStep2Icon"
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:src="@drawable/ic_circle_outline"
                                        app:tint="?attr/colorOutlineVariant"/>
                                    <View
                                        android:id="@+id/viewStep2Line"
                                        android:layout_width="2dp"
                                        android:layout_height="48dp"
                                        android:background="?attr/colorOutlineVariant"/>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:paddingBottom="24dp">
                                    <TextView
                                        android:id="@+id/tvStep2Title"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Payment Completed"
                                        android:textColor="?attr/colorOnSurfaceVariant"
                                        android:fontFamily="sans-serif-bold"
                                        android:textSize="15sp"/>
                                    <TextView
                                        android:id="@+id/tvStep2Status"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Locked"
                                        android:textColor="?attr/colorOnSurfaceVariant"
                                        android:fontFamily="sans-serif-medium"
                                        android:textSize="13sp"/>
                                </LinearLayout>
                            </LinearLayout>

                            <!-- ITEM 3: Insurance Process -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:gravity="center_horizontal"
                                    android:layout_marginEnd="16dp">
                                    <ImageView
                                        android:id="@+id/ivStep3Icon"
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:src="@drawable/ic_circle_outline"
                                        app:tint="?attr/colorOutlineVariant"/>
                                    <View
                                        android:id="@+id/viewStep3Line"
                                        android:layout_width="2dp"
                                        android:layout_height="48dp"
                                        android:background="?attr/colorOutlineVariant"/>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:paddingBottom="24dp">
                                    <TextView
                                        android:id="@+id/tvStep3Title"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Insurance Process"
                                        android:textColor="?attr/colorOnSurfaceVariant"
                                        android:fontFamily="sans-serif-bold"
                                        android:textSize="15sp"/>
                                    <TextView
                                        android:id="@+id/tvStep3Status"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Locked"
                                        android:textColor="?attr/colorOnSurfaceVariant"
                                        android:fontFamily="sans-serif-medium"
                                        android:textSize="13sp"/>
                                </LinearLayout>
                            </LinearLayout>

                            <!-- ITEM 4: Document Verification -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:gravity="center_horizontal"
                                    android:layout_marginEnd="16dp">
                                    <ImageView
                                        android:id="@+id/ivStep4Icon"
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:src="@drawable/ic_circle_outline"
                                        app:tint="?attr/colorOutlineVariant"/>
                                    <View
                                        android:id="@+id/viewStep4Line"
                                        android:layout_width="2dp"
                                        android:layout_height="48dp"
                                        android:background="?attr/colorOutlineVariant"/>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:paddingBottom="24dp">
                                    <TextView
                                        android:id="@+id/tvStep4Title"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Document Verification"
                                        android:textColor="?attr/colorOnSurfaceVariant"
                                        android:fontFamily="sans-serif-bold"
                                        android:textSize="15sp"/>
                                    <TextView
                                        android:id="@+id/tvStep4Status"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Locked"
                                        android:textColor="?attr/colorOnSurfaceVariant"
                                        android:fontFamily="sans-serif-medium"
                                        android:textSize="13sp"/>
                                </LinearLayout>
                            </LinearLayout>

                            <!-- ITEM 5: Tax Payment -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:gravity="center_horizontal"
                                    android:layout_marginEnd="16dp">
                                    <ImageView
                                        android:id="@+id/ivStep5Icon"
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:src="@drawable/ic_circle_outline"
                                        app:tint="?attr/colorOutlineVariant"/>
                                    <View
                                        android:id="@+id/viewStep5Line"
                                        android:layout_width="2dp"
                                        android:layout_height="48dp"
                                        android:background="?attr/colorOutlineVariant"/>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:paddingBottom="24dp">
                                    <TextView
                                        android:id="@+id/tvStep5Title"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Tax Payment"
                                        android:textColor="?attr/colorOnSurfaceVariant"
                                        android:fontFamily="sans-serif-bold"
                                        android:textSize="15sp"/>
                                    <TextView
                                        android:id="@+id/tvStep5Status"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Locked"
                                        android:textColor="?attr/colorOnSurfaceVariant"
                                        android:fontFamily="sans-serif-medium"
                                        android:textSize="13sp"/>
                                </LinearLayout>
                            </LinearLayout>

                            <!-- ITEM 6: Registration & RC Book -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:gravity="center_horizontal"
                                    android:layout_marginEnd="16dp">
                                    <ImageView
                                        android:id="@+id/ivStep6Icon"
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:src="@drawable/ic_circle_outline"
                                        app:tint="?attr/colorOutlineVariant"/>
                                    <!-- No Low Line for last item -->
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:paddingBottom="0dp">
                                    <TextView
                                        android:id="@+id/tvStep6Title"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Registration &amp; RC Book"
                                        android:textColor="?attr/colorOnSurfaceVariant"
                                        android:fontFamily="sans-serif-bold"
                                        android:textSize="15sp"/>
                                    <TextView
                                        android:id="@+id/tvStep6Status"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Locked"
                                        android:textColor="?attr/colorOnSurfaceVariant"
                                        android:fontFamily="sans-serif-medium"
                                        android:textSize="13sp"/>
                                </LinearLayout>
                            </LinearLayout>

                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Support Button -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnSupport"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/colorPrimaryContainer"
                    android:layout_marginTop="8dp"
                    android:foreground="?attr/selectableItemBackground">
                    
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:text="Need help with this order?"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        android:fontFamily="sans-serif-bold"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:drawablePadding="12dp"
                        app:drawableStartCompat="@drawable/ic_chat"
                        app:tint="?attr/colorOnPrimaryContainer" />
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>