<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base deep background -->
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:startColor="@color/charcoal_dark"
                android:endColor="#020617"
                android:type="linear" />
        </shape>
    </item>
    <!-- Primary Mesh Spot -->
    <item>
        <shape>
            <gradient
                android:type="radial"
                android:gradientRadius="400dp"
                android:startColor="#1A38BDF8"
                android:endColor="#00000000"
                android:centerX="85%"
                android:centerY="15%" />
        </shape>
    </item>
    <!-- Secondary Mesh Spot -->
    <item>
        <shape>
            <gradient
                android:type="radial"
                android:gradientRadius="600dp"
                android:startColor="#0D818CF8"
                android:endColor="#00000000"
                android:centerX="15%"
                android:centerY="85%" />
        </shape>
    </item>
</layer-list>
