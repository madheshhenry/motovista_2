<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7F8"
    android:fitsSystemWindows="true">

    <!-- MAIN CONTENT SCROLL AREA -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:clipToPadding="false"
        android:paddingTop="30dp"
        android:paddingBottom="120dp">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- TOP BAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="10dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_menu" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Welcome, Admin"
                    android:textStyle="bold"
                    android:textColor="#0D1B2A"
                    android:textSize="20sp"
                    android:gravity="center"/>

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_bell"/>
            </LinearLayout>

            <!-- PAGE TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Admin Dashboard"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#0E1111"
                android:paddingBottom="10dp"/>

            <!-- DASHBOARD CARDS -->
            <include layout="@layout/card_dashboard_item" android:id="@+id/cardEmi"/>
            <include layout="@layout/card_dashboard_item" android:id="@+id/cardInsurance"/>
            <include layout="@layout/card_dashboard_item" android:id="@+id/cardRegistration"/>
            <include layout="@layout/card_dashboard_item" android:id="@+id/cardApplication"/>
            <include layout="@layout/card_dashboard_item" android:id="@+id/cardSales"/>
            <include layout="@layout/card_dashboard_item" android:id="@+id/cardRequested"/>

            <!-- ADD NEW BIKE BUTTON -->
            <RelativeLayout
                android:id="@+id/btnAddBike"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_add_bike"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/addIcon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_add_white"
                    android:layout_alignParentStart="true"
                    android:layout_marginStart="20dp"
                    android:layout_centerVertical="true"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add New Bike"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:layout_centerInParent="true"/>
            </RelativeLayout>

            <!-- SECOND-HAND BIKE BUTTON -->
            <RelativeLayout
                android:id="@+id/btnAddSecondHand"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_second_bike"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/secondIcon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_exchange"
                    android:layout_alignParentStart="true"
                    android:layout_marginStart="20dp"
                    android:layout_centerVertical="true"/>


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add Second-Hand Bike"
                    android:textColor="#3A3A7A"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:layout_centerInParent="true"/>
            </RelativeLayout>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAVIGATION -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="82dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:itemIconSize="22dp"
        app:itemIconTint="@color/nav_selector"
        app:itemTextColor="@color/nav_selector"
        app:menu="@menu/bottom_nav_menu"/>


</RelativeLayout>
