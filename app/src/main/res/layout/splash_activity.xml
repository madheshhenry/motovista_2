<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <!-- Circle background -->
    <View
        android:id="@+id/circleBg"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:background="@drawable/circle_bg"
        android:layout_marginTop="100dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bike Icon (place your drawable ic_bike_logo) -->
    <ImageView
        android:id="@+id/logoIcon"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:src="@drawable/ic_bike_logo"
        android:contentDescription="logo"
        app:layout_constraintTop_toTopOf="@id/circleBg"
        app:layout_constraintBottom_toBottomOf="@id/circleBg"
        app:layout_constraintStart_toStartOf="@id/circleBg"
        app:layout_constraintEnd_toEndOf="@id/circleBg" />

    <!-- App Title -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Santhosh Bikes"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#000000"
        app:layout_constraintTop_toBottomOf="@id/circleBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/subTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MOTOVISTA"
        android:textColor="#00B4D8"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Tagline -->
    <TextView
        android:id="@+id/tagLine"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Ride, Your Passion"
        android:textColor="#7A7A7A"
        android:textSize="13sp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/subTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Progress Bar (use fixed dp width, NO %!!) -->
    <View
        android:id="@+id/loadingAnim"
        android:layout_width="120dp"
        android:layout_height="4dp"
        android:background="#00B4D8"
        app:layout_constraintBottom_toTopOf="@id/loadingText"
        android:layout_marginBottom="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- Loading text -->
    <TextView
        android:id="@+id/loadingText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:text="Loading premium experience..."
        android:textSize="12sp"
        android:textColor="#8A8A8A"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
