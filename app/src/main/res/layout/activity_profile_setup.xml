<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="18dp"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Complete Your Profile"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="#000000"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Help us personalize your experience."
            android:textSize="12sp"
            android:textColor="#777777"
            android:layout_marginTop="3dp"/>

        <!-- Profile Image -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="20dp"
            android:gravity="center">

            <ImageView
                android:id="@+id/imgProfile"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/ic_profile"
                android:scaleType="centerCrop"
                android:background="@drawable/circle_bg_white"
                android:padding="10dp" />

            <ImageButton
                android:id="@+id/btnAddPhoto"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="end|bottom"
                android:background="@drawable/circle_green"
                android:src="@drawable/ic_add"
                android:padding="6dp"/>
        </FrameLayout>

        <!-- DOB -->
        <EditText
            android:id="@+id/etDob"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="DD/MM/YYYY"
            android:background="@drawable/rounded_edittext"
            android:padding="15dp"
            android:focusable="false"
            android:drawableEnd="@drawable/ic_calendar"
            android:layout_marginTop="15dp"/>

        <!-- House No -->
        <EditText
            android:id="@+id/etHouse"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="House No."
            android:background="@drawable/rounded_edittext"
            android:padding="15dp"
            android:layout_marginTop="12dp"/>

        <!-- Street -->
        <EditText
            android:id="@+id/etStreet"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Street / Locality"
            android:background="@drawable/rounded_edittext"
            android:padding="15dp"
            android:layout_marginTop="12dp"/>

        <!-- City + State -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:weightSum="2"
            android:layout_marginTop="12dp">

            <EditText
                android:id="@+id/etCity"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="52dp"
                android:hint="City"
                android:background="@drawable/rounded_edittext"
                android:padding="15dp"/>

            <Space android:layout_width="10dp"/>

            <EditText
                android:id="@+id/etState"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="52dp"
                android:hint="State"
                android:background="@drawable/rounded_edittext"
                android:padding="15dp"/>
        </LinearLayout>

        <!-- Pincode -->
        <EditText
            android:id="@+id/etPincode"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Pincode"
            android:background="@drawable/rounded_edittext"
            android:padding="15dp"
            android:inputType="number"
            android:layout_marginTop="12dp"/>

        <!-- Aadhar Upload -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload Aadhar Card"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="15dp"/>

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:weightSum="2"
            android:layout_marginTop="8dp">

            <FrameLayout
                android:id="@+id/layoutFront"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:background="@drawable/dashed_box"
                android:gravity="center">

                <ImageView
                    android:id="@+id/imgAadharFront"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/ic_upload"/>
            </FrameLayout>

            <Space android:layout_width="10dp"/>

            <FrameLayout
                android:id="@+id/layoutBack"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:background="@drawable/dashed_box"
                android:gravity="center">

                <ImageView
                    android:id="@+id/imgAadharBack"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/ic_upload"/>
            </FrameLayout>
        </LinearLayout>

        <!-- PAN Number -->
        <EditText
            android:id="@+id/etPan"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Enter your PAN Number"
            android:background="@drawable/rounded_edittext"
            android:padding="15dp"
            android:layout_marginTop="14dp"/>

        <!-- Submit Button -->
        <Button
            android:id="@+id/btnComplete"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Complete Setup"
            android:background="@drawable/rounded_button_green"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:layout_marginTop="20dp"/>
    </LinearLayout>

</ScrollView>
